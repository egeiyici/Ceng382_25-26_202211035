@page
@model Ceng382_25_26_202211035.Pages.IndexModel
@{
    ViewData["Title"] = "Not Tablosu";
}

<div class="container mt-4">
    <div class="card shadow p-4">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2>Öğrenci Not Tablosu</h2>

            <button onclick="calculateGrades()" class="btn btn-success">
                Hesapla
            </button>
        </div>

        <table class="table table-bordered text-center">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Öğrenci</th>
                    <th>Vize</th>
                    <th>Final</th>
                    <th>Harf Notu</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td>@student.Id</td>
                        <td>@student.Name</td>
                        <td class="midterm">@student.Midterm</td>
                        <td class="final">@student.Final</td>
                        <td class="letter"></td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3 text-start">
            <strong>Hesaplama Metodu:</strong><br />
            Ortalama = Vize %40 + Final %60
        </div>

    </div>
</div>

<script>
    function calculateGrades() {

        const rows = document.querySelectorAll("tbody tr");

        rows.forEach(row => {

            const midterm = parseFloat(row.querySelector(".midterm").innerText);
            const final = parseFloat(row.querySelector(".final").innerText);

            const average = (midterm * 0.4) + (final * 0.6);

            let letter = "";

            if (average >= 90) letter = "AA";
            else if (average >= 85) letter = "BA";
            else if (average >= 80) letter = "BB";
            else if (average >= 75) letter = "CB";
            else if (average >= 70) letter = "CC";
            else if (average >= 65) letter = "DC";
            else if (average >= 60) letter = "DD";
            else if (average >= 50) letter = "FD";
            else letter = "FF";

            row.querySelector(".letter").innerText = letter;
        });
    }
</script>