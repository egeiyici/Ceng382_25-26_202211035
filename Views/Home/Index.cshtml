@model IEnumerable<Ceng382_25_26_202211035.Models.ShipperDisplayViewModel>

@{
    ViewData["Title"] = "Home Page";
}

<h2>Hard Delete Table</h2>

<table class="table table-bordered table-striped table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>ShipperId</th>
            <th>Email</th>
            <th>Website</th>
            <th>Phone</th>
            <th>Address</th>
            <th>City</th>
            <th>Country</th>
            <th>PostCode</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ShipperId</td>
                <td>@item.Email</td>
                <td>
                    <a href="https://@item.Website" target="_blank">
                        @item.Website
                    </a>
                </td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>@item.City</td>
                <td>@item.Country</td>
                <td>@item.PostCode</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ShipperId" class="btn btn-sm btn-warning">Edit</a>

                    <form asp-action="HardDelete" asp-route-id="@item.ShipperId" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<h2>Soft Delete Table</h2>

<table class="table table-bordered table-striped table-hover">
    <thead>
        <tr>
            <th>Id</th>
            <th>ShipperId</th>
            <th>Email</th>
            <th>Website</th>
            <th>Phone</th>
            <th>Address</th>
            <th>City</th>
            <th>Country</th>
            <th>PostCode</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.Where(x => x.IsVisible))
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.ShipperId</td>
                <td>@item.Email</td>
                <td>
                    <a href="https://@item.Website" target="_blank">
                        @item.Website
                    </a>
                </td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>@item.City</td>
                <td>@item.Country</td>
                <td>@item.PostCode</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.ShipperId" class="btn btn-sm btn-warning">Edit</a>

                    <form asp-action="SoftDelete" asp-route-id="@item.ShipperId" method="post" style="display:inline;">
                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>